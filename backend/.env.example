DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="1d"
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# --- Email (for OTP + receipt PDF) ---
# Free options:
#   Gmail:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  user=you@gmail.com  pass=<app password>
#   Brevo:  SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587  (300 emails/day free)
# If unset, OTP codes are logged to the backend console (dev mode).
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Mall Inventory <no-reply@example.com>"
STORE_NAME="Mall Inventory"
